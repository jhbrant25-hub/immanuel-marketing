# Buffer — get token at buffer.com → Settings → Apps & Integrations → API
BUFFER_TOKEN=your_buffer_token_here
BUFFER_PROFILE_X=your_x_profile_id
BUFFER_PROFILE_INSTAGRAM=your_instagram_profile_id
BUFFER_PROFILE_FACEBOOK=your_facebook_profile_id

# Formspree — get ID at formspree.io (free, 50 submissions/month)
FORMSPREE_ID=your_formspree_form_id
